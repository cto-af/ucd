{
  "name": "@cto.af/ucd",
  "version": "1.1.4",
  "decription": "Retrieve, cache, and parse current Unicode Character Database files.",
  "main": "lib/index.js",
  "type": "module",
  "keywords": [
    "unicode",
    "ucd",
    "tr44",
    "parse"
  ],
  "author": "Joe Hildebrand <joe-github@cursive.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cto-af/ucd.git"
  },
  "homepage": "https://github.com/cto-af/ucd#readme",
  "bugs": {
    "url": "https://github.com/cto-af/ucd/issues"
  },
  "files": [
    "lib/*"
  ],
  "scripts": {
    "clean": "rm -rf lib coverage docs src/ucd.js src/ucd.d.ts",
    "docs": "typedoc",
    "lint": "eslint .",
    "parser": "peggy -c peggy.config.js",
    "prebuild": "npm run parser",
    "build": "tsup",
    "pretest": "npm run build -- --sourcemap inline --no-minify",
    "test": "c8 node --test --enable-source-maps",
    "posttest": "tsup --silent",
    "start": "hostlocal"
  },
  "dependencies": {
    "@cto.af/log": "1.3.6",
    "@cto.af/utils": "1.4.2"
  },
  "devDependencies": {
    "@cto.af/eslint-config": "6.2.5",
    "@peggyjs/coverage": "2.0.5",
    "@types/node": "25.3.3",
    "enhanced-resolve": "5.20.0",
    "eslint": "10.0.2",
    "hostlocal": "2.4.1",
    "peggy": "5.1.0",
    "superc8": "^12.2.4",
    "tsup": "8.5.1",
    "typedoc": "0.28.17",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  }
}
